/**
 * 이 함수 하나만 실행하세요.
 *
 * - 최초 실행: 사업자등록증 일괄 폴더 전체 중 안 읽은 파일부터 OCR
 * - 중간에 끊김: 같은 함수 다시 실행하면 이어서 진행
 * - 전체 완료 후 재실행: 새로 추가된 파일만 OCR
 */
function runBusinessRegistrationOcr() {
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    const cfg = BR_OCR_CFG;
    const ss = brOcrGetSpreadsheet_();
    const driveId = brOcrGetSharedDriveId_();
    const sourceFolder = brOcrGetSourceFolder_(driveId);
    const outputSheet = brOcrEnsureOutputSheet_(ss);
    const outputHeaderMap = brOcrGetOutputHeaderMap_(outputSheet);

    const files = brOcrListDirectNonFolderFilesPaged_(sourceFolder.id, driveId);

    if (files.length === 0) {
      Logger.log(`"${cfg.SOURCE_FOLDER_NAME}" 폴더에 OCR 대상 파일이 없습니다.`);
      return;
    }

    const recordedFileIds = brOcrGetRecordedFileIdSet_(outputSheet, outputHeaderMap);
    const indexes = brOcrBuildAllIndexes_({
      ss,
      driveId
    });

    const props = PropertiesService.getScriptProperties();
    let fileIndex = Number(props.getProperty(cfg.PROP_NEXT_FILE_INDEX) || 0);

    if (fileIndex >= files.length) {
      props.deleteProperty(cfg.PROP_NEXT_FILE_INDEX);
      fileIndex = 0;
    }

    const startedAt = Date.now();

    let scanned = 0;
    let attempted = 0;
    let ocrRead = 0;
    let rowsWritten = 0;
    let skipped = 0;
    let errors = 0;
    let rateLimited = false;

    const rowsToAppend = [];

    while (
      fileIndex < files.length &&
      attempted < cfg.MAX_FILES_PER_RUN &&
      Date.now() - startedAt < cfg.MAX_MILLIS_PER_RUN
    ) {
      const file = files[fileIndex];

      try {
        if (cfg.SKIP_ALREADY_RECORDED_FILE_ID && recordedFileIds[file.id]) {
          skipped++;
          fileIndex++;
          scanned++;
          continue;
        }

        attempted++;

        brOcrAppendProgressLog_({
          file,
          fileIndex,
          status: 'START_OCR',
          message: 'OCR 시작'
        });

        SpreadsheetApp.flush();

        const oneFileRows = brOcrProcessOneFile_({
          file,
          indexes
        });

        oneFileRows.forEach(row => rowsToAppend.push(row));

        if (rowsToAppend.length >= BR_OCR_CFG.APPEND_BATCH_SIZE) {
          brOcrAppendOutputRows_(outputSheet, rowsToAppend);
          rowsToAppend.length = 0;
          SpreadsheetApp.flush();
        }

        brOcrAppendProgressLog_({
          file,
          fileIndex,
          status: 'DONE_OCR',
          message: `OCR 완료 / 기록 예정 행 ${oneFileRows.length}개`
        });

        recordedFileIds[file.id] = true;
        ocrRead++;
        rowsWritten += oneFileRows.length;

        if (BR_OCR_CFG.OCR_COOLDOWN_MS && BR_OCR_CFG.OCR_COOLDOWN_MS > 0) {
          Utilities.sleep(BR_OCR_CFG.OCR_COOLDOWN_MS);
        }

      } catch (err) {
        errors++;

        const errMessage = err && err.message ? err.message : String(err);

        if (brOcrIsRateLimitError_(err)) {
          rateLimited = true;

          brOcrAppendProgressLog_({
            file,
            fileIndex,
            status: 'RATE_LIMIT_STOP',
            message: 'OCR 쿼터 제한 감지. 현재 파일은 결과 시트에 완료 처리하지 않고 다음 실행에서 재시도합니다. 원문 오류: ' + errMessage
          });

          // 현재 파일부터 다시 시도해야 하므로 fileIndex를 증가시키지 않고 중단.
          break;
        }

        brOcrAppendProgressLog_({
          file,
          fileIndex,
          status: 'ERROR',
          message: errMessage
        });

        const parsed = brOcrParseBusinessRegistrationFileName_(file.name);
        const nowText = brOcrNowText_();

        rowsToAppend.push(brOcrMakeOutputRow_({
          customerNo: '',
          contractNo: (parsed.contractNos || []).join(','),
          file,
          ocrAt: nowText,
          corpName: '',
          representative: '',
          businessNo: '',
          address: '',
          businessType: '',
          businessItem: '',
          status: 'OCR_ERROR',
          message: errMessage,
          ocrText: ''
        }));

        if (rowsToAppend.length >= BR_OCR_CFG.APPEND_BATCH_SIZE) {
          brOcrAppendOutputRows_(outputSheet, rowsToAppend);
          rowsToAppend.length = 0;
          SpreadsheetApp.flush();
        }

        // 일반 OCR_ERROR는 다음 실행에서 재시도 가능하도록 recordedFileIds에는 넣지 않습니다.
      }

      fileIndex++;
      scanned++;
    }

    brOcrAppendOutputRows_(outputSheet, rowsToAppend);

    if (fileIndex < files.length) {
      props.setProperty(cfg.PROP_NEXT_FILE_INDEX, String(fileIndex));

      if (rateLimited) {
        Logger.log(
          `OCR 쿼터 제한으로 중단: 스캔 ${scanned}개 / 시도 ${attempted}개 / OCR성공 ${ocrRead}개 / 기록행 ${rowsWritten}행 / 기존스킵 ${skipped}개 / 오류 ${errors}개. ` +
          `10~30분 뒤 같은 runBusinessRegistrationOcr()를 다시 실행하세요. 재시도 파일 순번: ${fileIndex + 1}`
        );
      } else {
        Logger.log(
          `사업자등록증 OCR 이번 실행 완료: 스캔 ${scanned}개 / 시도 ${attempted}개 / OCR성공 ${ocrRead}개 / 기록행 ${rowsWritten}행 / 기존스킵 ${skipped}개 / 오류 ${errors}개. ` +
          `아직 남았습니다. 같은 runBusinessRegistrationOcr()를 다시 실행하세요. 다음 파일 순번: ${fileIndex + 1}`
        );
      }

    } else {
      props.deleteProperty(cfg.PROP_NEXT_FILE_INDEX);

      Logger.log(
        `사업자등록증 OCR 전체 완료: 스캔 ${scanned}개 / 시도 ${attempted}개 / OCR성공 ${ocrRead}개 / 기록행 ${rowsWritten}행 / 기존스킵 ${skipped}개 / 오류 ${errors}개`
      );
    }

  } finally {
    lock.releaseLock();
  }
}


/***** 파일 1개 처리 *****/

function brOcrProcessOneFile_(params) {
  const file = params.file;
  const indexes = params.indexes;

  const parsedName = brOcrParseBusinessRegistrationFileName_(file.name);

  const sizeBytes = Number(file.size || 0);
  if (sizeBytes && sizeBytes > BR_OCR_CFG.MAX_SOURCE_FILE_SIZE_BYTES) {
    const nowText = brOcrNowText_();

    return [brOcrMakeOutputRow_({
      customerNo: '',
      contractNo: (parsedName.contractNos || []).join(','),
      file,
      ocrAt: nowText,
      corpName: '',
      representative: '',
      businessNo: '',
      address: '',
      businessType: '',
      businessItem: '',
      status: 'SKIPPED_TOO_LARGE',
      message: `파일 용량 초과로 OCR 스킵: ${sizeBytes} bytes`,
      ocrText: ''
    })];
  }

  const ocrText = brOcrReadFileTextByDocumentAi_(file);
  const extracted = brOcrExtractBusinessRegistrationFields_(ocrText);

  const targets = brOcrResolveCustomersForFile_({
    parsedName,
    extracted,
    indexes
  });

  const nowText = brOcrNowText_();
  const rows = [];

  if (!targets || targets.length === 0) {
    rows.push(brOcrMakeOutputRow_({
      customerNo: '',
      contractNo: (parsedName.contractNos || []).join(','),
      file,
      ocrAt: nowText,
      corpName: extracted.corpName,
      representative: extracted.representative,
      businessNo: extracted.businessNo,
      address: extracted.address,
      businessType: extracted.businessType,
      businessItem: extracted.businessItem,
      status: 'NO_CUSTOMER_MATCH',
      message: '고객번호 매칭 실패',
      ocrText
    }));

    return rows;
  }

  targets.forEach(target => {
    rows.push(brOcrMakeOutputRow_({
      customerNo: target.customerNo || '',
      contractNo: target.contractNo || '',
      file,
      ocrAt: nowText,
      corpName: extracted.corpName,
      representative: extracted.representative,
      businessNo: extracted.businessNo,
      address: extracted.address,
      businessType: extracted.businessType,
      businessItem: extracted.businessItem,
      status: target.customerNo ? 'OK' : 'NO_CUSTOMER_MATCH',
      message: target.message || '',
      ocrText
    }));
  });

  return rows;
}


/***** Document AI OCR *****/

function brOcrReadFileTextByDocumentAi_(file) {
  brOcrAssertDocumentAiConfig_();

  const blob = brOcrDownloadDriveFileAsBlob_(file.id, file.name);
  const mimeType = brOcrResolveSupportedMimeType_(file, blob);

  const url = brOcrBuildDocumentAiProcessUrl_();

  const payload = {
    rawDocument: {
      content: Utilities.base64Encode(blob.getBytes()),
      mimeType: mimeType,
      displayName: brOcrSanitizeDocumentAiDisplayName_(file.name)
    }
  };

  const res = UrlFetchApp.fetch(url, {
    method: 'post',
    muteHttpExceptions: true,
    contentType: 'application/json; charset=utf-8',
    payload: JSON.stringify(payload),
    headers: {
      Authorization: 'Bearer ' + ScriptApp.getOAuthToken()
    }
  });

  const code = res.getResponseCode();
  const text = res.getContentText();

  if (code < 200 || code >= 300) {
    throw new Error(`Document AI OCR 실패 ${code}: ${file.name} / ${text}`);
  }

  const data = JSON.parse(text);
  const docText = data && data.document && data.document.text ? data.document.text : '';

  return brOcrCleanOcrText_(docText);
}


function brOcrBuildDocumentAiProcessUrl_() {
  const cfg = BR_OCR_CFG;

  const projectId = brOcrCleanValue_(cfg.DOCUMENT_AI_PROJECT_ID);
  const location = brOcrCleanValue_(cfg.DOCUMENT_AI_LOCATION || 'us');
  const processorId = brOcrCleanValue_(cfg.DOCUMENT_AI_PROCESSOR_ID);
  const versionId = brOcrCleanValue_(cfg.DOCUMENT_AI_PROCESSOR_VERSION_ID);

  if (versionId) {
    return (
      'https://' + encodeURIComponent(location) + '-documentai.googleapis.com/v1/' +
      'projects/' + encodeURIComponent(projectId) +
      '/locations/' + encodeURIComponent(location) +
      '/processors/' + encodeURIComponent(processorId) +
      '/processorVersions/' + encodeURIComponent(versionId) +
      ':process'
    );
  }

  return (
    'https://' + encodeURIComponent(location) + '-documentai.googleapis.com/v1/' +
    'projects/' + encodeURIComponent(projectId) +
    '/locations/' + encodeURIComponent(location) +
    '/processors/' + encodeURIComponent(processorId) +
    ':process'
  );
}


function brOcrAssertDocumentAiConfig_() {
  const cfg = BR_OCR_CFG;

  const missing = [];

  if (!brOcrCleanValue_(cfg.DOCUMENT_AI_PROJECT_ID)) missing.push('DOCUMENT_AI_PROJECT_ID');
  if (!brOcrCleanValue_(cfg.DOCUMENT_AI_LOCATION)) missing.push('DOCUMENT_AI_LOCATION');
  if (!brOcrCleanValue_(cfg.DOCUMENT_AI_PROCESSOR_ID)) missing.push('DOCUMENT_AI_PROCESSOR_ID');

  if (missing.length > 0) {
    throw new Error(
      'Document AI 설정값이 비어 있습니다: ' + missing.join(', ') +
      '. BR_OCR_CFG에 Google Cloud 프로젝트 ID / location / processor ID를 입력하세요.'
    );
  }
}


function brOcrResolveSupportedMimeType_(file, blob) {
  const fileMime = brOcrCleanValue_(file.mimeType);
  const blobMime = brOcrCleanValue_(blob.getContentType());
  const name = brOcrCleanValue_(file.name).toLowerCase();

  let mimeType = fileMime || blobMime;

  if (!mimeType || mimeType === 'application/octet-stream') {
    if (/\.pdf$/i.test(name)) mimeType = 'application/pdf';
    else if (/\.(jpg|jpeg)$/i.test(name)) mimeType = 'image/jpeg';
    else if (/\.png$/i.test(name)) mimeType = 'image/png';
    else if (/\.tif|\.tiff$/i.test(name)) mimeType = 'image/tiff';
    else if (/\.gif$/i.test(name)) mimeType = 'image/gif';
    else if (/\.bmp$/i.test(name)) mimeType = 'image/bmp';
    else if (/\.webp$/i.test(name)) mimeType = 'image/webp';
  }

  const allowed = {
    'application/pdf': true,
    'image/jpeg': true,
    'image/jpg': true,
    'image/png': true,
    'image/tiff': true,
    'image/gif': true,
    'image/bmp': true,
    'image/webp': true
  };

  if (!allowed[mimeType]) {
    throw new Error(`Document AI OCR 미지원 또는 미확인 MIME type: ${mimeType} / 파일명: ${file.name}`);
  }

  if (mimeType === 'image/jpg') return 'image/jpeg';

  return mimeType;
}


function brOcrSanitizeDocumentAiDisplayName_(name) {
  // Document AI RawDocument displayName의 예약문자 제거
  return brOcrCleanValue_(name)
    .replace(/[*?\[\]%{}'",~=]/g, ' ')
    .replace(/[:]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 240);
}


function brOcrDownloadDriveFileAsBlob_(fileId, fileName) {
  const url =
    'https://www.googleapis.com/drive/v2/files/' +
    encodeURIComponent(fileId) +
    '?alt=media&supportsAllDrives=true';

  const res = UrlFetchApp.fetch(url, {
    method: 'get',
    muteHttpExceptions: true,
    headers: {
      Authorization: 'Bearer ' + ScriptApp.getOAuthToken()
    }
  });

  const code = res.getResponseCode();

  if (code < 200 || code >= 300) {
    throw new Error(`OCR 원본 파일 다운로드 실패 ${code}: ${fileName} / ${res.getContentText()}`);
  }

  return res.getBlob().setName(fileName || 'ocr_source');
}


